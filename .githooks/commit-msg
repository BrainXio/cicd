#!/usr/bin/env bash
# BrainXio commit-msg hook — blocks AI attribution in commit messages
set -euo pipefail

msg_file="$1"
if [ ! -f "$msg_file" ]; then
  exit 0
fi

content=$(grep -v '^#' "$msg_file" || true)

ATTRIBUTION_PATTERNS=(
  "[Cc]o-authored[- ]by"
  "[Gg]enerated[- ]by[- ]AI"
  "[Aa]I[- ]generated"
  "[Ww]ritten[- ]by[- ](Claude|ChatGPT|Copilot|Gemini)"
  "[Cc]reated[- ]with[- ](Claude|ChatGPT|Copilot|Gemini)"
  "GitHub[- ]Copilot"
)

violations=0
for pattern in "${ATTRIBUTION_PATTERNS[@]}"; do
  matches=$(echo "$content" | grep -inE "$pattern" 2>/dev/null || true)
  if [ -n "$matches" ]; then
    echo "ERROR: forbidden attribution pattern in commit message:" >&2
    echo "$matches" | head -5 >&2
    violations=$((violations + 1))
  fi
done

if [ "$violations" -gt 0 ]; then
  echo "Commit message attribution guard failed: $violations violation(s). Remove AI attribution." >&2
  exit 1
fi

exit 0
