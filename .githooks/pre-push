#!/usr/bin/env bash
# Comprehensive pre-push validation
# Blocks push if any check fails
set -euo pipefail

echo "Running pre-push validation..."

errors=0
warnings=0

# ====================== AI ATTRIBUTION SCAN ======================
echo "Scanning git log for AI attributions..."

ATTRIBUTION_PATTERNS=(
  "[Cc]o-authored[- ]by"
  "[Gg]enerated[- ]by[- ]AI"
  "[Aa]I[- ]generated"
  "[Ww]ritten[- ]by[- ](Claude|ChatGPT|Copilot|Gemini|Grok|LLaMA)"
  "[Cc]reated[- ]with[- ](Claude|ChatGPT|Copilot|Gemini|Grok|LLaMA)"
  "GitHub[- ]Copilot"
  "# AI[- ]generated"
  "[Aa]ssisted[- ]by[- ](Claude|ChatGPT|Copilot|Gemini|Grok|LLaMA)"
  "[Uu]sing[- ](Claude|ChatGPT|Copilot|Gemini|Grok|LLaMA)"
  "llm[- ]generated"
  "language[- ]model[- ]generated"
)

# Scan commits being pushed
if [ -n "$(git log --format=%B --grep='.' "origin/main..HEAD" 2>/dev/null || true)" ]; then
  for pattern in "${ATTRIBUTION_PATTERNS[@]}"; do
    matches=$(git log --format=%B "origin/main..HEAD" | grep -inE "$pattern" 2>/dev/null || true)
    if [ -n "$matches" ]; then
      echo "WARNING: Possible AI attribution in commit history:" >&2
      echo "$matches" | head -5 >&2
      warnings=$((warnings + 1))
    fi
  done
fi

# ====================== SECRET PATTERN DETECTION ======================
echo "Scanning for potential secrets in staged files..."

# Patterns that indicate secrets
SECRET_PATTERNS=(
  'api[_-]?key.*=.*["'\''""][^"'\''""]{20,}["'\''""]'
  'token.*=.*["'\''""][^"'\''""]{20,}["'\''""]'
  'password.*=.*["'\''""][^"'\''""]{8,}["'\''""]'
  'secret.*=.*["'\''""][^"'\''""]{10,}["'\''""]'
  'ghp_[a-zA-Z0-9]{36}'
  'gho_[a-zA-Z0-9]{36}'
  'github_pat_[a-zA-Z0-9]{22,}'
  'sk-[a-zA-Z0-9]{48}'
  'AKIA[0-9A-Z]{16}'
  'ASIA[0-9A-Z]{16}'
  'bearer\s+[a-zA-Z0-9_\-]{20,}'
  'basic\s+[a-zA-Z0-9+/]{20,}={0,2}'
  'xox[baprs]-[0-9]{10,}'
  'eyJ[a-zA-Z0-9_-]*\.eyJ[a-zA-Z0-9_-]*\.[a-zA-Z0-9_-]*'
  'private[_-]?key'
  'BEGIN\s+(RSA|DSA|EC|OPENSSH)\s+PRIVATE\s+KEY'
)

# Check staged files for secrets
staged=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
for file in $staged; do
  [ -f "$file" ] || continue
  # Skip lock files and binary files
  [[ "$file" == *.lock ]] && continue
  [[ "$file" == *.sum ]] && continue

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if grep -inE "$pattern" "$file" 2>/dev/null | head -1 | grep -q .; then
      echo "WARNING: Potential secret pattern detected in $file" >&2
      grep -inE "$pattern" "$file" 2>/dev/null | head -3 >&2
      warnings=$((warnings + 1))
      break
    fi
  done
done

# ====================== MERGE CONFLICT MARKERS ======================
echo "Checking for merge conflict markers..."

if git grep -lE '^(<<<<<<< |>>>>>>> |=======$)' -- '*.py' '*.ts' '*.tsx' '*.rs' '*.go' '*.yml' '*.yaml' '*.md' '*.toml' '*.json' '*.sh' '*.bash' '*.css' '*.html' '*.tf' '*.hcl' '*.sql' '*.xml' 2>/dev/null | grep -q .; then
  echo "ERROR: Merge conflict markers found:" >&2
  git grep -nE '^(<<<<<<< |>>>>>>> |=======$)' -- '*.py' '*.ts' '*.tsx' '*.rs' '*.go' '*.yml' '*.yaml' '*.md' '*.toml' '*.json' '*.sh' '*.bash' '*.css' '*.html' '*.tf' '*.hcl' '*.sql' '*.xml' 2>/dev/null | head -10 >&2
  errors=$((errors + 1))
fi

# ====================== TRAILING WHITESPACE ======================
echo "Checking for trailing whitespace..."

trailing_files=$(git diff --cached --check 2>/dev/null | grep 'trailing whitespace' | cut -d: -f1 | sort -u || true)
if [ -n "$trailing_files" ]; then
  echo "ERROR: Trailing whitespace found in:" >&2
  echo "$trailing_files" | head -10 >&2
  errors=$((errors + 1))
fi

# ====================== LARGE FILES ======================
echo "Checking for large files..."

# Check for files > 1MB in staged changes
large_files=$(git diff --cached --stat --numstat 2>/dev/null | awk '$1 > 1048576 || $2 > 1048576 {print $3}' || true)
if [ -n "$large_files" ]; then
  echo "ERROR: Large files detected (>1MB):" >&2
  echo "$large_files" | head -5 >&2
  errors=$((errors + 1))
fi

# ====================== BINARY FILES IN SOURCE ======================
echo "Checking for unexpected binary files..."

binary_patterns=(
  '*.exe' '*.dll' '*.so' '*.dylib' '*.bin'
  '*.o' '*.a' '*.obj' '*.lib'
  '*.pyc' '*.pyo' '__pycache__/'
  '*.class' '*.jar'
  '*.min.js' '*.min.css'
  '*.wasm'
  '*.pdf' '*.doc' '*.docx'
  '*.zip' '*.tar' '*.gz' '*.rar' '*.7z'
  '*.png' '*.jpg' '*.jpeg' '*.gif' '*.bmp' '*.ico' '*.svg'
  '*.mp3' '*.mp4' '*.avi' '*.mov' '*.wav'
)

for pattern in "${binary_patterns[@]}"; do
  found=$(git diff --cached --name-only --diff-filter=ACM | grep -iE "${pattern}$" 2>/dev/null || true)
  if [ -n "$found" ]; then
    echo "WARNING: Binary/non-source file staged: $found" >&2
    warnings=$((warnings + 1))
  fi
done

# ====================== EXECUTABLE BIT ON NON-SCRIPTS ======================
echo "Checking executable permissions..."

# Find files with executable bit that are not shell scripts
while IFS= read -r -d '' file; do
  [ -f "$file" ] || continue
  # Skip actual scripts
  [[ "$file" == *.sh ]] && continue
  [[ "$file" == *.bash ]] && continue
  [[ "$file" == .githooks/* ]] && continue

  echo "WARNING: Executable bit set on non-script file: $file" >&2
  warnings=$((warnings + 1))
done < <(git diff --cached --name-only --diff-filter=ACM -z 2>/dev/null | xargs -0 stat -c '%A %n' 2>/dev/null | grep '^...x' | awk '{print $2}' | tr '\n' '\0' || true)

# ====================== FULL YAML VALIDATION ======================
echo "Running full YAML validation..."

while IFS= read -r -d '' file; do
  # Skip files with Jinja2 templates (they need template validation instead)
  if grep -q '{{' "$file" 2>/dev/null || grep -q '{%' "$file" 2>/dev/null; then
    echo "  SKIP (contains Jinja2): $file"
    continue
  fi

  if ! python3 -c 'import yaml, sys; yaml.safe_load(open(sys.argv[1]))' "$file" 2>/dev/null; then
    echo "ERROR: Invalid YAML syntax in $file" >&2
    errors=$((errors + 1))
  else
    echo "  OK (YAML): $file"
  fi
done < <(find . -type f \( -name "*.yaml" -o -name "*.yml" \) \
  -not -path "./.github/*" \
  -not -path "./.git/*" \
  -not -path "./.claude/*" \
  -not -path "./.pytest_cache/*" \
  -print0 2>/dev/null || true)

# ====================== FULL JINJA2 TEMPLATE VALIDATION ======================
echo "Running full Jinja2 template validation..."

# Validate standalone Jinja2 template files
while IFS= read -r -d '' file; do
  if ! python3 -c '
import sys
import jinja2
file_path = sys.argv[1]
try:
    with open(file_path, "r") as f:
        source = f.read()
    jinja2.Environment().parse(source)
    print(f"  OK (Jinja2): {file_path}")
except jinja2.TemplateSyntaxError as e:
    print(f"ERROR: Jinja2 syntax error in {file_path}: {e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f"ERROR: Jinja2 validation failed for {file_path}: {e}", file=sys.stderr)
    sys.exit(1)
' "$file" 2>/dev/null; then
    errors=$((errors + 1))
  fi
done < <(find . -type f \( -name "*.jinja" -o -name "*.jinja2" -o -name "*.j2" \) \
  -not -path "./.git/*" \
  -not -path "./.claude/*" \
  -print0 2>/dev/null || true)

# Validate Jinja2 templates embedded in YAML files
while IFS= read -r -d '' file; do
  if ! grep -q '{{' "$file" 2>/dev/null && ! grep -q '{%' "$file" 2>/dev/null; then
    continue
  fi

  echo "  CHECK (Jinja2 in YAML): $file"

  if ! python3 -c '
import sys
import os
from jinja2 import Environment, FileSystemLoader, TemplateSyntaxError

file_path = sys.argv[1]
dir_path = os.path.dirname(file_path) or "."
template_name = os.path.basename(file_path)

env = Environment(loader=FileSystemLoader(dir_path))
try:
    env.get_template(template_name)
    print(f"  OK (Jinja2 in YAML): {file_path}")
except TemplateSyntaxError as e:
    print(f"ERROR: Jinja2 syntax error in {file_path}: {e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f"ERROR: Jinja2 validation failed for {file_path}: {e}", file=sys.stderr)
    sys.exit(1)
' "$file" 2>/dev/null; then
    errors=$((errors + 1))
  fi
done < <(find . -type f \( -name "*.yaml" -o -name "*.yml" \) \
  -not -path "./.github/*" \
  -not -path "./.git/*" \
  -not -path "./.claude/*" \
  -print0 2>/dev/null || true)

# ====================== LANGUAGE-SPECIFIC VALIDATION ======================

# Python syntax check
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.py$'; then
  echo "Running Python syntax validation..."
  while IFS= read -r -d '' file; do
    if ! python3 -m py_compile "$file" 2>/dev/null; then
      echo "ERROR: Python syntax error in $file" >&2
      errors=$((errors + 1))
    else
      echo "  OK (Python): $file"
    fi
  done < <(git diff --cached --name-only --diff-filter=ACM -z | grep -z '\.py$' || true)
fi

# Shell script syntax check
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.sh$'; then
  echo "Running shell script validation..."
  while IFS= read -r -d '' file; do
    if ! bash -n "$file" 2>/dev/null; then
      echo "ERROR: Shell syntax error in $file" >&2
      errors=$((errors + 1))
    else
      echo "  OK (Shell): $file"
    fi
  done < <(git diff --cached --name-only --diff-filter=ACM -z | grep -z '\.sh$' || true)
fi

# JSON syntax check
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.json$'; then
  echo "Running JSON validation..."
  while IFS= read -r -d '' file; do
    if ! python3 -c 'import json, sys; json.load(open(sys.argv[1]))' "$file" 2>/dev/null; then
      echo "ERROR: Invalid JSON in $file" >&2
      errors=$((errors + 1))
    else
      echo "  OK (JSON): $file"
    fi
  done < <(git diff --cached --name-only --diff-filter=ACM -z | grep -z '\.json$' || true)
fi

# Go syntax check
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.go$'; then
  echo "Running Go syntax validation..."
  if command -v gofmt &> /dev/null; then
    while IFS= read -r -d '' file; do
      if ! gofmt -e "$file" > /dev/null 2>&1; then
        echo "ERROR: Go syntax error in $file" >&2
        errors=$((errors + 1))
      else
        echo "  OK (Go): $file"
      fi
    done < <(git diff --cached --name-only --diff-filter=ACM -z | grep -z '\.go$' || true)
  fi
fi

# Rust syntax check
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.rs$'; then
  echo "Running Rust syntax validation..."
  if command -v rustc &> /dev/null; then
    while IFS= read -r -d '' file; do
      if ! rustc --crate-type lib -Z parse-only "$file" 2>/dev/null; then
        echo "ERROR: Rust syntax error in $file" >&2
        errors=$((errors + 1))
      else
        echo "  OK (Rust): $file"
      fi
    done < <(git diff --cached --name-only --diff-filter=ACM -z | grep -z '\.rs$' || true)
  fi
fi

# TypeScript/JavaScript syntax check
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.(ts|tsx|js|jsx)$'; then
  echo "Running TypeScript/JavaScript validation..."
  if command -v npx &> /dev/null; then
    while IFS= read -r -d '' file; do
      if ! npx eslint --quiet "$file" 2>/dev/null; then
        echo "WARNING: TypeScript/JavaScript lint issues in $file" >&2
        warnings=$((warnings + 1))
      else
        echo "  OK (TS/JS): $file"
      fi
    done < <(git diff --cached --name-only --diff-filter=ACM -z | grep -zE '\.(ts|tsx|js|jsx)$' || true)
  fi
fi

# ====================== SUMMARY ======================
echo ""
echo "=== Pre-push Validation Summary ==="
echo "Errors:   $errors"
echo "Warnings: $warnings"

if [ "$errors" -gt 0 ]; then
  echo "" >&2
  echo "Pre-push validation FAILED: $errors error(s) found." >&2
  echo "Fix the errors above and try again." >&2
  exit 1
fi

if [ "$warnings" -gt 0 ]; then
  echo ""
  echo "Pre-push validation passed with $warnings warning(s)."
else
  echo "Pre-push validation PASSED."
fi

exit 0
