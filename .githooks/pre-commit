#!/usr/bin/env bash
# Validate YAML files parse correctly, validate Jinja2 templates compile
# Skips YAML files under .github/
set -euo pipefail

# Allowed namespaces (bash array)
ALLOWED_NAMESPACES=("BrainXio" "brainxio")

echo "Running pre-commit validation..."

# Validate repository namespace
remote_url=$(git remote get-url origin 2>/dev/null || echo "")
if [ -n "$remote_url" ]; then
  namespace=$(echo "$remote_url" | sed -n 's/.*github\.com[:/]\([^/]*\)\/.*/\1/p')
  if [ -n "$namespace" ]; then
    allowed=false
    for allowed_ns in "${ALLOWED_NAMESPACES[@]}"; do
      if [ "$namespace" = "$allowed_ns" ]; then
        allowed=true
        break
      fi
    done
    if [ "$allowed" = false ]; then
      echo "ERROR: Repository namespace '$namespace' is not allowed." >&2
      echo "Allowed namespaces: ${ALLOWED_NAMESPACES[*]}" >&2
      exit 1
    fi
    echo "  OK: namespace '$namespace' is allowed"
  fi
fi

# Get staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -z "$staged_files" ]; then
  exit 0
fi

errors=0

# ====================== YAML VALIDATION ======================
echo "Validating YAML files..."
yaml_files=$(echo "$staged_files" | grep -E '\.(ya?ml|yaml)$' || true)

for file in $yaml_files; do
  # Skip .github/ directory YAML files
  if [[ "$file" == .github/* ]]; then
    echo "  Skipping .github/ file: $file"
    continue
  fi

  if [ ! -f "$file" ]; then
    continue
  fi

  # Check if file contains Jinja2 templates
  if grep -q '{{.*}}' "$file" || grep -q '{%.*%}' "$file"; then
    echo "  Skipping Jinja2 template (will be validated by pre-push): $file"
    continue
  fi

  # Validate YAML syntax
  if ! uvx --from yamllint yamllint -d relaxed "$file" 2>/dev/null; then
    echo "ERROR: Invalid YAML in $file" >&2
    errors=$((errors + 1))
  else
    echo "  OK: $file"
  fi
done

# ====================== JINJA2 TEMPLATE VALIDATION ======================
echo "Validating Jinja2 templates..."
jinja_files=$(echo "$staged_files" | grep -E '\.(ya?ml|yaml|j2|jinja2)$' || true)

for file in $jinja_files; do
  # Skip .github/ directory files
  if [[ "$file" == .github/* ]]; then
    echo "  Skipping .github/ file: $file"
    continue
  fi

  if [ ! -f "$file" ]; then
    continue
  fi

  # Check if file contains Jinja2 syntax
  if grep -q '{{.*}}' "$file" || grep -q '{%.*%}' "$file"; then
    # Try to compile the Jinja2 template
    if ! uvx --from jinja2-cli jinja2-cli --help >/dev/null 2>&1; then
      # Fallback: basic syntax check with Python
      if ! uv run python -c "
import sys
from jinja2 import Environment, FileSystemLoader, TemplateSyntaxError

env = Environment(loader=FileSystemLoader('.'))
try:
    env.get_template('$file')
    print('  OK (Jinja2): $file')
except TemplateSyntaxError as e:
    print(f'ERROR: Jinja2 syntax error in $file: {e}', file=sys.stderr)
    sys.exit(1)
" 2>/dev/null; then
        echo "ERROR: Jinja2 template compilation failed: $file" >&2
        errors=$((errors + 1))
      fi
    else
      echo "  OK (Jinja2): $file"
    fi
  fi
done

# ====================== GITHUB ACTIONS PINNING VALIDATION ======================
echo "Validating GitHub Actions pinning..."
workflow_files=$(echo "$staged_files" | grep -E '^\.github/workflows/.*\.(ya?ml|yaml)$' || true)

if [ -n "$workflow_files" ]; then
  validate_script="$(dirname "$0")/../scripts/validate-action-pinning.sh"
  if [ -f "$validate_script" ]; then
    if ! "$validate_script" $workflow_files; then
      echo "ERROR: GitHub Actions pinning validation failed." >&2
      errors=$((errors + 1))
    fi
  else
    echo "WARNING: Validation script not found: $validate_script" >&2
  fi
fi

# ====================== SUMMARY ======================
if [ "$errors" -gt 0 ]; then
  echo "" >&2
  echo "Pre-commit validation failed: $errors error(s) found." >&2
  exit 1
fi

echo "Pre-commit validation passed."
exit 0
